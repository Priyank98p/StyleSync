# Server Configuration
PORT=8000
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/stylesync
CORS_ORIGIN=*

# Cloudinary (Image Hosting)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# JWT Authentication
ACCESS_TOKEN_SECRET=generate_a_random_secret_string_here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=generate_another_random_secret_string_here
REFRESH_TOKEN_EXPIRY=10d

# Admin Panel Credentials
ADMIN_EMAIL=admin@stylesync.com
ADMIN_PASS=secure_admin_password_here

# Payment Gateways (Use Test/Sandbox Keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here